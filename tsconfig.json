{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",    
    "baseUrl": "./src",                      // ✅ adicionado
    "typeRoots": ["./src/@types", "./node_modules/@types"] // ✅ adicionado
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
